{
  "name": "paragliding-agent",
  "version": "1.0.0",
  "description": "Daily paragliding conditions brief via Claude",
  "scripts": {
    "build:agent": "tsc -p tsconfig.node.json",
    "build:frontend": "vite build",
    "build": "npm run build:agent && npm run build:frontend",
    "start": "node dist/run_ci.js",
    "dev": "tsx run_local.ts",
